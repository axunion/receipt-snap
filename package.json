{
	"name": "receipt-snap",
	"private": true,
	"type": "module",
	"version": "0.0.0",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "24.16.0",
			"onFail": "warn"
		},
		"packageManager": {
			"name": "pnpm",
			"version": "11.5.0",
			"onFail": "warn"
		}
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"check": "biome check ./src && tsc --noEmit",
		"fix": "biome check --write ./src",
		"prepare": "lefthook install",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"solid-js": "^1.9.10"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@iconify-icon/solid": "^3.0.1",
		"@solidjs/testing-library": "^0.8.10",
		"@testing-library/jest-dom": "^6.9.1",
		"@types/node": "^24.6.0",
		"@vitest/coverage-v8": "^4.1.7",
		"browserslist": "^4.28.1",
		"happy-dom": "^20.6.1",
		"lefthook": "^2.1.9",
		"lightningcss": "^1.31.1",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-solid": "^2.11.8",
		"vitest": "^4.0.18"
	}
}
