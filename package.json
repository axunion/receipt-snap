{
  "name": "receipt-snap",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "license": "MIT",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "^11",
      "onFail": "warn"
    }
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "biome check && tsc --noEmit",
    "fix": "biome check --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "solid-js": "^1.9.10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@iconify-icon/solid": "^3.0.1",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^4.1.7",
    "browserslist": "^4.28.1",
    "happy-dom": "^20.6.1",
    "lefthook": "^2.1.9",
    "typescript": "~5.9.3",
    "vite": "^8.1.3",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.0.18"
  }
}
